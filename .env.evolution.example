# Copie este arquivo para .env.evolution na VPS e preencha com os dados reais.

# Endereco publico da Evolution API.
# Exemplo: https://evolution.seudominio.com
SERVER_URL=https://evolution.seudominio.com
EVOLUTION_PORT=8080

# Chave que o JuriStack vai usar em EVOLUTION_API_KEY.
AUTHENTICATION_API_KEY=troque-por-uma-chave-segura

# Banco interno da Evolution API.
POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=troque-por-uma-senha-segura
